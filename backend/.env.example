## Backend environment variables (example)

# Server
PORT=3000

# Secret for encrypting stored Playerok token at rest.
# You can use either name below (TOKEN_SECRET preferred).
TOKEN_SECRET=
# HEAD_CODE=

# User-Agent for Playerok requests (used as "code from header")
PLAYEROK_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36

# Исходящий HTTP(S) прокси для запросов к playerok.com (опционально).
# Приоритет: PLAYEROK_PROXY, иначе HTTPS_PROXY, иначе HTTP_PROXY.
# Пример: http://user:pass@proxy.example.com:8080
# PLAYEROK_PROXY=

# Дополнительные cookie для обхода JS-челленджа DDoS-Guard в server-side запросах.
# Скопируйте из браузера (DevTools -> Application -> Cookies -> https://playerok.com) только пары name=value
# и перечислите через "; ". Пример:
# PLAYEROK_DDOS_COOKIE=__ddg2_=abc123; __ddgu_=xyz456
# PLAYEROK_DDOS_COOKIE=

# Устаревший fallback: один IP для всех запросов, если в UI (Настройки → исходящие IP) ничего не задано.
# Предпочтительно настраивать в /settings по категориям (лоты, чаты, сделки…).
# Пример: PLAYEROK_OUTBOUND_IP=62.181.53.145
# В Docker адрес должен быть на интерфейсе процесса (network_mode: host), иначе EADDRNOTAVAIL.
# PLAYEROK_OUTBOUND_IP=

# Подробные логи автозапроса кода Supercell и определения категории в чатах.
# PLAYEROK_SUPERCELL_DEBUG=1
# Логи извлечения почты из сделки при загрузке сообщений чата:
# PLAYEROK_DEAL_EMAIL_DEBUG=1

# AppRoute API (автовыдача Api). Базовый URL, если отличается от https://approute.ru/api/v1
# APPROUTE_API_BASE=https://approute.ru/api/v1

# Clode API (Автовыдача Clode — активация Claude CDK). Базовый URL, если отличается
# от https://dlsapi.6661231.xyz/api/v1. Сам API-ключ хранится зашифрованным в БД
# (вводится в настройках UI), а не здесь.
# CLODE_API_BASE=https://dlsapi.6661231.xyz/api/v1
# CLODE_TASK_POLL_MAX_MS=120000
# CLODE_TASK_POLL_INTERVAL_MS=3000

# GPT API (Автовыдача GPT — активация ChatGPT-подписок по карт-кодам).
# Базовый URL, если отличается от https://api.987ai.vip. Глобального ключа у этого
# API нет — авторизует сам card_key из привязанной таблицы.
# GPT_API_BASE=https://api.987ai.vip
# GPT_TASK_POLL_MAX_MS=120000
# GPT_TASK_POLL_INTERVAL_MS=3000
# GPT_DOC_RECHECK_SEC=8     # как часто перепроверять доступ к Google-доку
# GPT_STOCK_RETRY_SEC=20    # пауза перед авто-ретраем активации при пустом складе/сбое

# Вход в панель — только регистрация на сайте (таблица users в SQLite), без логина/пароля в .env.
