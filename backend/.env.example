## Backend environment variables (example)

# Server
PORT=3000

# Enable auth if AUTH_LOGIN is set
AUTH_LOGIN=admin

# Preferred: hashed password (scrypt). Example format:
# scrypt$<saltBase64>$<keyBase64>
AUTH_PASSWORD_HASH=

# Legacy (NOT recommended): plaintext password
# AUTH_PASSWORD=changeme

# Secret for encrypting stored Playerok token at rest.
# You can use either name below (TOKEN_SECRET preferred).
TOKEN_SECRET=
# HEAD_CODE=

# User-Agent for Playerok requests (used as "code from header")
PLAYEROK_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36

# Порт сервера (по умолчанию 3000)
# PORT=3000

# Аутентификация: только залогиненный пользователь сможет зайти в панель.
# Задайте логин и пароль — без них вход будет закрыт.
AUTH_LOGIN=admin
AUTH_PASSWORD=your-secret-password
