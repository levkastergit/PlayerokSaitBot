Go

Copy
package webhook

import (
	"crypto/hmac"
	"crypto/sha256"
	"encoding/hex"
	"fmt"
	"io"
	"net/http"
	"strconv"
	"strings"
	"time"
)

// Handler verifies the signature over the RAW body bytes, then dispatches.
func Handler(secret []byte, dispatch func([]byte)) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		raw, _ := io.ReadAll(r.Body)
		_ = r.Body.Close()
		var t int64
		var v1 string
		for _, kv := range strings.Split(r.Header.Get("X-Auth-Donat-Signature"), ",") {
			if i := strings.IndexByte(kv, '='); i > 0 {
				if kv[:i] == "t" {
					t, _ = strconv.ParseInt(kv[i+1:], 10, 64)
				} else if kv[:i] == "v1" {
					v1 = kv[i+1:]
				}
			}
		}
		w.WriteHeader(http.StatusOK) // 2xx even on reject — no retry storm
		if v1 == "" || abs64(time.Now().Unix()-t) > 300 {
			return
		}
		mac := hmac.New(sha256.New, secret)
		fmt.Fprintf(mac, "%d.", t)
		mac.Write(raw)
		got, err := hex.DecodeString(v1)
		if err != nil || !hmac.Equal(got, mac.Sum(nil)) {
			return
		}
		dispatch(raw)
	}
}

func abs64(x int64) int64 { if x < 0 { return -x }; return x }
