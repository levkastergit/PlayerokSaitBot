// No node:crypto in the Workers runtime — use WebCrypto. Same
// algorithm, different primitives. Read the body as bytes (do NOT
// call .json() before verifying) and HMAC over `${t}.${rawBody}`.
export default {
  async fetch(req, env) {
    const header = req.headers.get('X-Auth-Donat-Signature') ?? '';
    let t = NaN, v1 = '';
    for (const part of header.split(',')) {
      const [k, v] = part.split('=');
      if (k === 't')  t  = parseInt(v ?? '', 10);
      if (k === 'v1') v1 = v ?? '';
    }
    if (!Number.isFinite(t) || !v1) return new Response('rejected', { status: 200 });
    if (Math.abs(Date.now() / 1000 - t) > 300) return new Response('rejected', { status: 200 });

    const raw = await req.arrayBuffer();
    const enc = new TextEncoder();
    const tBytes = enc.encode(`${t}.`);
    const body = new Uint8Array(raw);
    const msg = new Uint8Array(tBytes.length + body.length);
    msg.set(tBytes, 0); msg.set(body, tBytes.length);

    const key = await crypto.subtle.importKey('raw', enc.encode(env.WEBHOOK_SECRET),
      { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    const sig = new Uint8Array(await crypto.subtle.sign('HMAC', key, msg));
    const expected = Array.from(sig, (b) => b.toString(16).padStart(2, '0')).join('');

    // Constant-time hex compare.
    if (expected.length !== v1.length) return new Response('rejected', { status: 200 });
    let diff = 0;
    for (let i = 0; i < expected.length; i++) diff |= expected.charCodeAt(i) ^ v1.charCodeAt(i);
    if (diff !== 0) return new Response('rejected', { status: 200 });

    await dispatch(JSON.parse(new TextDecoder().decode(raw)));
    return new Response('ok', { status: 200 });
  },
};
