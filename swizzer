{
  "object": "service_announcement",
  "active": true,                 // true ONLY when enabled AND text non-empty — when false, ignore text
  "text": "Scheduled maintenance 02:00-03:00 UTC; deliveries may be delayed.",
  "severity": "warning"           // "info" | "warning" | "critical"  (info = safe default)
